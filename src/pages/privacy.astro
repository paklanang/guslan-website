---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Privacy Policy — Guslan Putra',
  description: 'Privacy policy website guslan.com.',
  robots: { index: false, follow: false },  // ✅ FIX: object, bukan string
};
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-8">Terakhir diperbarui: Mei 2026</p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Informasi yang Dikumpulkan</h2>
    <p>Website ini mengumpulkan informasi yang kamu berikan secara sukarela melalui form kontak, seperti nama, email, dan pesan. Informasi ini digunakan semata-mata untuk merespons pertanyaan atau permintaan konsultasi.</p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Analytics</h2>
    <p>Website ini menggunakan Cloudflare Web Analytics yang bersifat privacy-friendly dan tidak menggunakan cookies atau melacak data pribadi.</p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Kontak</h2>
    <p>Pertanyaan terkait privacy policy dapat disampaikan melalui <a href="https://wa.me/628213141688" class="text-primary hover:underline">WhatsApp</a>.</p>
  </section>
</Layout>