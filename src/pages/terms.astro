---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Terms of Service — Guslan Putra',
  description: 'Terms of service website guslan.com.',
  robots: { index: false, follow: false }, // ✅ FIX: object, bukan string
};
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8">Terms of Service</h1>
    <p class="text-sm text-gray-500 mb-8">Terakhir diperbarui: Mei 2026</p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Penggunaan Konten</h2>
    <p>
      Seluruh konten di guslan.com — artikel, tools, dan template — adalah milik Guslan Putra. Konten boleh dibagikan
      dengan menyertakan sumber, namun tidak boleh direproduksi secara komersial tanpa izin.
    </p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Disclaimer</h2>
    <p>
      Informasi di website ini bersifat edukatif dan tidak menggantikan konsultasi profesional. Untuk keputusan keuangan
      dan perpajakan spesifik, disarankan untuk berkonsultasi langsung.
    </p>

    <h2 class="text-xl font-semibold mt-8 mb-3">Kontak</h2>
    <p>
      Pertanyaan dapat disampaikan melalui <a href="https://wa.me/628213141688" class="text-primary hover:underline"
        >WhatsApp</a
      >.
    </p>
  </section>
</Layout>
