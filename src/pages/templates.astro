---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Templates Gratis F&B — Guslan Putra',
  description:
    'Template HPP, cash flow, dan kalkulator keuangan gratis khusus bisnis F&B. Segera hadir.',
};
---

<Layout metadata={metadata}>
  <section class="py-24 px-4">
    <div class="max-w-2xl mx-auto text-center">

      <div class="inline-flex items-center gap-2 bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
        Sedang Disiapkan
      </div>

      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">
        Template Gratis F&B<br />Segera Hadir
      </h1>

      <p class="text-slate-500 dark:text-slate-400 leading-relaxed mb-8">
        Saya sedang menyiapkan kumpulan template siap pakai untuk owner cafe dan restoran:
      </p>

      <ul class="text-left max-w-sm mx-auto space-y-3 mb-10">
        {[
          'Kalkulator HPP per menu (Google Sheets)',
          'Cash Flow Tracker bulanan F&B',
          'Checklist Finansial Pemilik F&B',
          'Template Budget Tahunan Restoran',
          'Panduan Hitung BEP Cafe',
        ].map((item) => (
          <li class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
            <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {item}
          </li>
        ))}
      </ul>

      <p class="text-sm text-slate-500 dark:text-slate-400 mb-8">
        Mau dapat notifikasi saat template sudah live? Chat saya sekarang.
      </p>

      <a
        href="https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20mau%20dapat%20notifikasi%20saat%20template%20F%26B%20sudah%20tersedia"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-primary hover:bg-teal-700 text-white font-bold py-3.5 px-8 rounded-xl transition-all duration-200 hover:shadow-lg text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.847L.057 23.882l6.197-1.623A11.95 11.95 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.887 9.887 0 01-5.031-1.371l-.361-.214-3.741.981 1.001-3.645-.235-.374A9.856 9.856 0 012.106 12C2.106 6.58 6.58 2.106 12 2.106S21.894 6.58 21.894 12 17.42 21.894 12 21.894z"/>
        </svg>
        Kabari Saya via WhatsApp
      </a>

    </div>
  </section>
</Layout>