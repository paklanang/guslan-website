---
// src/pages/index.astro
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Guslan Putra — Konsultan Keuangan & Akuntansi F&B Bali',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════
       HERO — Pain-driven, dari guslan.id lama
  ══════════════════════════════════════════════ -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Free Financial Health Check',
        href: 'https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20ingin%20jadwalkan%20Financial%20Health%20Check%20gratis%2045%20menit',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Download Template Gratis', href: '/templates' },
    ]}
    image={{
      src: '~/assets/images/Guslan-Putra-konsultan-keuangan-fnb-2.webp',
      alt: 'Konsultan Keuangan F&B Bali — Guslan Putra',
    }}
  >
    <Fragment slot="title">
      Restoran Ramai Tiap Hari,<br />
      Tapi Uang di Bank
      <span class="text-accent dark:text-white"> Selalu Menipis?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Saatnya memahami cerita di balik angka —
      <span class="font-semibold">bukan dengan feeling, tapi dengan data.</span>
      <br />
      Saya bantu restoran dan cafe Anda punya sistem keuangan yang jelas,
      pajak yang tertata, dan keputusan bisnis berbasis fakta.
    </Fragment>
  </Hero>

  <!-- ═══════════════════════════════════════════
       NOTE
  ══════════════════════════════════════════════ -->
  <Note
    title="Finance Growth Partner"
    description="Bukan sekadar akuntan — saya bantu Anda paham angka, kontrol keuangan, dan tumbuh dengan data yang jelas."
  />

  <!-- ═══════════════════════════════════════════
       4 PAIN POINTS — Dari guslan.id lama
  ══════════════════════════════════════════════ -->
  <Features
    id="masalah"
    tagline="Kenali Tandanya"
    title="4 Tanda Bisnis F&B Anda Butuh Sistem Keuangan yang Lebih Baik"
    subtitle="Jika Anda merasakan minimal 2 dari situasi ini, sudah waktunya berbenah."
    items={[
      {
        title: 'Profit Besar di Laporan, Kas Menipis di Bank',
        description:
          'Omzet ratusan juta tapi selalu bertanya-tanya: "uang ke mana ya?" Tidak ada pemisahan jelas antara modal, operasional, dan profit.',
        icon: 'tabler:building-bank',
      },
      {
        title: 'Tidak Tahu Menu Mana yang Benar-Benar Untung',
        description:
          'Menu signature yang ramai bisa jadi yang margin-nya paling tipis. Tanpa COGS yang akurat, Anda baru tahu setelah rugi besar.',
        icon: 'tabler:tools-kitchen-2',
      },
      {
        title: 'Cemas Soal Pajak Restoran',
        description:
          'PKP atau Non-PKP? PPN, PPh, PB1 — semuanya membingungkan. Banyak cafe di Bali kena masalah bukan karena niat jahat, tapi karena tidak paham sistemnya.',
        icon: 'tabler:receipt-tax',
      },
      {
        title: 'Keputusan Bisnis Pakai Feeling, Bukan Data',
        description:
          'Mau buka cabang? Tambah menu? Rekrut staf? Tanpa data yang jelas, semua keputusan seperti gambling — risiko tinggi, return tidak pasti.',
        icon: 'tabler:chart-bar-off',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       KALKULATOR HPP — Ide Gemini, diperbaiki
  ══════════════════════════════════════════════ -->
  <section id="kalkulator" class="bg-blue-50 dark:bg-slate-800 py-16 px-4 scroll-mt-16">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">Mini Health Check</p>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">
          Cek HPP Bisnis F&B Anda Sekarang
        </h2>
        <p class="text-slate-500 dark:text-slate-400">
          Masukkan 2 angka, dapatkan gambaran awal kondisi keuangan bisnis Anda.
        </p>
      </div>

      <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-xl p-8 border border-slate-100 dark:border-slate-700">
        <!-- Input Row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
          <div>
            <label for="omzet" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
              Omzet Bulanan (Rp)
            </label>
            <input
              type="number"
              id="omzet"
              placeholder="Contoh: 150000000"
              min="0"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="hpp" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
              HPP / Food Cost (%)
            </label>
            <input
              type="number"
              id="hpp"
              placeholder="Contoh: 38"
              min="0"
              max="100"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
            />
          </div>
        </div>

        <!-- Tidak tahu HPP? -->
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">
          Tidak yakin berapa HPP Anda?
          <a
            href="https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20tidak%20tahu%20HPP%20bisnis%20saya.%20Bisa%20bantu%3F"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary font-semibold hover:underline"
          >
            Tanya Guslan gratis →
          </a>
        </p>

        <!-- Tombol Cek -->
        <button
          id="calcBtn"
          class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-3.5 rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
        >
          Cek Kondisi HPP Saya
        </button>

        <!-- Hasil -->
        <div id="result" class="hidden mt-6 rounded-xl p-5 border-l-4 transition-all">
          <div class="flex items-start gap-3">
            <span id="resultIcon" class="text-2xl mt-0.5 shrink-0"></span>
            <div>
              <p id="resultStatus" class="font-bold text-base mb-1"></p>
              <p id="resultText" class="text-sm leading-relaxed text-slate-600 dark:text-slate-300"></p>
              <p id="resultAction" class="text-sm mt-3 font-medium"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Disclaimer kecil -->
      <p class="text-center text-xs text-slate-400 mt-4">
        Hasil ini adalah estimasi awal. Kondisi nyata bisnis Anda bisa berbeda tergantung jenis F&B dan struktur biaya.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEAD MAGNET — Dua jalur gratis
  ══════════════════════════════════════════════ -->
  <Features
    id="mulai"
    tagline="Mulai dari Sini"
    title="Pilih Cara yang Paling Sesuai — Keduanya Gratis"
    subtitle="Tidak ada komitmen, tidak ada tekanan. Mulai dari mana yang paling nyaman untuk Anda."
    items={[
      {
        title: 'Download Template HPP + Cash Flow',
        description:
          'Kalkulator HPP per menu & cash flow tracker bulanan untuk cafe/restoran. Lengkap dengan video tutorial dan Checklist Finansial Pemilik F&B. Cocok untuk Anda yang ingin mulai kelola keuangan sendiri.',
        icon: 'tabler:file-spreadsheet',
      },
      {
        title: 'Free Financial Health Check (45 Menit)',
        description:
          'Video call langsung dengan saya: quick review kondisi keuangan bisnis, identifikasi 3 masalah finansial terbesar, dan rekomendasi prioritas perbaikan. Cocok untuk yang ingin rekomendasi personal dan spesifik.',
        icon: 'tabler:stethoscope',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       CARA KERJA — 4 langkah
  ══════════════════════════════════════════════ -->
  <Steps
    title="Cara Saya Bekerja Dengan Anda"
    subtitle="Sederhana, transparan, kolaboratif — tidak ada jargon yang membingungkan."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Assessment</span>',
        description:
          'Sesi konsultasi awal untuk memahami struktur bisnis, sistem yang sudah ada, dan tantangan utama Anda. Output: rekomendasi langkah konkret yang bisa diambil segera.',
        icon: 'tabler:clipboard-list',
      },
      {
        title: 'Step 2: <span class="font-medium">Review & Diagnose</span>',
        description:
          'Audit laporan keuangan dan sistem yang berjalan. Identifikasi masalah utama: arus kas, COGS, margin, pajak. Output: Financial Health Report + prioritas perbaikan.',
        icon: 'tabler:search',
      },
      {
        title: 'Step 3: <span class="font-medium">Setup & Integration</span>',
        description:
          'Bangun sistem pembukuan yang rapi — Chart of Accounts F&B, integrasi POS (MOKA, ESB, Accurate), dashboard real-time, SOP, dan training tim. Output: sistem yang berjalan otomatis.',
        icon: 'tabler:settings',
      },
      {
        title: 'Step 4: <span class="font-medium">Monitoring & Growth</span>',
        description:
          'Monthly financial review, analisa tren, dan rekomendasi optimasi pricing dan menu. Output: business insights yang actionable setiap bulan untuk keputusan berbasis data.',
        icon: 'tabler:trending-up',
      },
    ]}
    image={{
      src: '~/assets/images/Guslan-Putra-konsultan-keuangan-fnb-3.webp',
      alt: 'Proses kerja konsultasi keuangan F&B Guslan Putra',
    }}
  />

  <!-- ═══════════════════════════════════════════
       KENAPA GUSLAN
  ══════════════════════════════════════════════ -->
  <Content
    isReversed
    tagline="Tentang Saya"
    title="Konsultan yang Benar-Benar Paham Bisnis Kuliner"
    items={[
      {
        title: 'Spesialis F&B — Bukan Akuntan Generalis',
        description:
          'Saya hanya fokus di restoran, cafe, bakery & Pastry, ghost Kitchen, warung. Paham bedanya food cost warung nasi vs kafe specialty coffee vs fine dining.',
      },
      {
        title: '15 Tahun di Industri, 5 Tahun Fokus F&B',
        description:
          'Bukan teori dari buku teks — pengalaman langsung di keuangan pariwisata dan operasional F&B Bali. Paham seasonal, cash flow harian, dan dinamika unik bisnis kuliner.',
      },
      {
        title: 'Bahasa Manusia, Bukan Bahasa Akuntan',
        description:
          'Laporan dijelaskan dengan contoh konkret yang bisa langsung Anda gunakan untuk keputusan. Tidak ada laporan tebal yang berakhir di laci.',
      },
    ]}
    image={{
      src: '~/assets/images/Guslan-Putra-Konsultan-Keuangan-FnB-Bali-1.webp',
      alt: 'Guslan Putra — Konsultan Keuangan F&B Bali',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Berbasis di Bali, Melayani Seluruh Indonesia
      </h3>
      Remote-friendly. Klien dari Bali, Jakarta, Surabaya, hingga Lombok — semua dilayani dengan support penuh.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- ═══════════════════════════════════════════
       STATS
  ══════════════════════════════════════════════ -->
  <Stats
    stats={[
      { title: 'Tahun Pengalaman Keuangan', amount: '15+' },
      { title: 'Fokus Operasional F&B', amount: '5 Thn' },
      { title: 'Sistem Keuangan Dirapikan', amount: '20+' },
      { title: 'Kota di Bali Dilayani', amount: '6' },
    ]}
  />

  <!-- ═══════════════════════════════════════════
       BLOG
  ══════════════════════════════════════════════ -->
  <BlogLatestPosts
    title="Edukasi Gratis untuk Owner F&B"
    information="Artikel praktis seputar keuangan, pajak, dan HPP khusus bisnis kuliner. Langsung bisa diterapkan — tidak perlu background akuntansi."
  />

  <!-- ═══════════════════════════════════════════
       FAQ
  ══════════════════════════════════════════════ -->
  <FAQs
    title="Pertanyaan yang Sering Ditanyakan"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Apakah bisa konsultasi secara online?',
        description:
          'Ya, semua layanan bisa dilakukan remote via WhatsApp atau Zoom. Klien saya ada di Bali, Jakarta, Surabaya, dan kota lainnya di Indonesia.',
      },
      {
        title: 'Melayani area mana saja di Bali?',
        description:
          'Tatap muka untuk area Badung dan Denpasar: Canggu, Seminyak, Kuta, Ubud, Jimbaran, Nusa Dua, Sanur. Area lain di Bali dan luar Bali via konsultasi online dengan support penuh.',
      },
      {
        title: 'Apakah cocok untuk bisnis kecil yang baru mulai?',
        description:
          'Sangat cocok. Justru membangun sistem yang benar sejak awal jauh lebih mudah dan murah daripada memperbaiki yang sudah kacau.',
      },
      {
        title: 'Apakah saya perlu paham akuntansi dulu?',
        description:
          'Tidak perlu sama sekali. Saya yang urus teknisnya — Anda cukup pahami angka-angka kunci bisnis Anda. Saya jelaskan dengan bahasa yang mudah dipahami.',
      },
      {
        title: 'Berapa biaya layanannya?',
        description:
          'Disesuaikan dengan skala bisnis dan kebutuhan Anda. Konsultasi pertama gratis — tidak ada komitmen, tidak ada tekanan.',
      },
      {
        title: 'Berapa lama sebelum hasilnya terasa?',
        description:
          'Dalam 2–4 minggu pertama, sistem sudah lebih rapi. Dalam 1–3 bulan, Anda sudah punya visibilitas penuh atas kondisi keuangan bisnis.',
      },
    ]}
  />

  <!-- Link ke FAQ lengkap -->
  <div class="text-center pb-10 -mt-4">
    <p class="text-slate-500 dark:text-slate-400 text-sm">
      Masih ada pertanyaan?
      <a href="/faq" class="text-primary font-semibold hover:underline ml-1">Lihat 20+ FAQ lengkap →</a>
    </p>
  </div>

  <!-- ═══════════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════════════ -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Jadwalkan Financial Health Check Gratis',
        href: 'https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20ingin%20jadwalkan%20Financial%20Health%20Check%20gratis',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      {
        text: 'Download Template Gratis',
        href: '/templates',
      },
    ]}
  >
    <Fragment slot="title">
      Jangan Biarkan Keuangan yang Berantakan<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap"> Menghambat Pertumbuhan Bisnis Anda</span>
    </Fragment>
    <Fragment slot="subtitle">
      Dengan sistem yang tepat, Anda fokus ke menu, tim, dan pelanggan —<br class="hidden md:inline" />
      sementara saya bantu handle angka dan kepatuhan pajak.
    </Fragment>
  </CallToAction>

  <!-- ═══════════════════════════════════════════
     KALKULATOR SCRIPT — Sederhana tapi informatif
══════════════════════════════════════════════ -->
<script is:inline>
  document.getElementById('calcBtn').addEventListener('click', function () {
    const omzetVal = parseFloat(document.getElementById('omzet').value);
    const hppVal = parseFloat(document.getElementById('hpp').value);
    const resultDiv = document.getElementById('result');
    const resultIcon = document.getElementById('resultIcon');
    const resultStatus = document.getElementById('resultStatus');
    const resultText = document.getElementById('resultText');
    const resultAction = document.getElementById('resultAction');

    if (!omzetVal || !hppVal || omzetVal <= 0 || hppVal <= 0 || hppVal > 100) {
      resultDiv.className = 'mt-6 rounded-xl p-5 border-l-4 bg-yellow-50 dark:bg-yellow-900/20 border-yellow-400';
      resultIcon.textContent = '⚠️';
      resultStatus.textContent = 'Data belum lengkap';
      resultStatus.className = 'font-bold text-base mb-1 text-yellow-700 dark:text-yellow-300';
      resultText.textContent = 'Masukkan omzet bulanan dan persentase HPP Anda terlebih dahulu.';
      resultAction.textContent = '';
      resultDiv.classList.remove('hidden');
      return;
    }

    const biayaHPP = omzetVal * (hppVal / 100);
    const sisaSetelahHPP = omzetVal - biayaHPP;
    const formatRp = (n) =>
      'Rp ' + Math.round(n).toLocaleString('id-ID');

    let icon, status, statusClass, text, action;

    if (hppVal <= 28) {
      icon = '🟢';
      statusClass = 'font-bold text-base mb-1 text-green-700 dark:text-green-300';
      status = 'HPP Sangat Efisien';
      text = `Dari omzet ${formatRp(omzetVal)}, biaya bahan baku Anda ${formatRp(biayaHPP)} (${hppVal}%). Sisa ${formatRp(sisaSetelahHPP)} untuk menutup biaya operasional lain dan profit. HPP Anda di bawah standar industri — bagus! Fokus selanjutnya: pastikan biaya operasional lain juga terkontrol.`;
      action = '✅ Langkah selanjutnya: optimalkan biaya tenaga kerja dan overhead untuk maksimalkan profit bersih.';
      resultDiv.className = 'mt-6 rounded-xl p-5 border-l-4 bg-green-50 dark:bg-green-900/20 border-green-400';
    } else if (hppVal <= 35) {
      icon = '🔵';
      statusClass = 'font-bold text-base mb-1 text-blue-700 dark:text-blue-300';
      status = 'HPP Normal — Masih Sehat';
      text = `Dari omzet ${formatRp(omzetVal)}, biaya bahan baku Anda ${formatRp(biayaHPP)} (${hppVal}%). Sisa ${formatRp(sisaSetelahHPP)} untuk biaya operasional dan profit. HPP Anda berada di kisaran sehat (28–35% untuk restoran/cafe).`;
      action = '💡 Langkah selanjutnya: lakukan audit menu untuk tahu menu mana yang paling menguntungkan.';
      resultDiv.className = 'mt-6 rounded-xl p-5 border-l-4 bg-blue-50 dark:bg-blue-900/20 border-blue-400';
    } else if (hppVal <= 45) {
      icon = '🟡';
      statusClass = 'font-bold text-base mb-1 text-yellow-700 dark:text-yellow-300';
      status = 'HPP Di Atas Normal — Perlu Perhatian';
      text = `Dari omzet ${formatRp(omzetVal)}, biaya bahan baku Anda ${formatRp(biayaHPP)} (${hppVal}%). Dengan HPP ${hppVal}%, margin Anda menyempit. Ada potensi kebocoran di pembelian bahan baku, porsi, atau waste yang belum terkontrol.`;
      action = '⚡ Disarankan: audit porsi dan supplier sekarang sebelum margin terus terkikis.';
      resultDiv.className = 'mt-6 rounded-xl p-5 border-l-4 bg-yellow-50 dark:bg-yellow-900/20 border-yellow-400';
    } else {
      icon = '🔴';
      statusClass = 'font-bold text-base mb-1 text-red-700 dark:text-red-300';
      status = 'HPP Kritis — Bisnis Berpotensi Rugi';
      text = `Dari omzet ${formatRp(omzetVal)}, biaya bahan baku saja sudah ${formatRp(biayaHPP)} (${hppVal}%). Dengan HPP di atas 45%, sangat sulit menutup biaya operasional lain seperti sewa, gaji, dan listrik. Ini sinyal darurat yang perlu ditangani segera.`;
      action = '🚨 Segera konsultasikan kondisi ini — jangan tunggu sampai cash flow makin kritis.';
      resultDiv.className = 'mt-6 rounded-xl p-5 border-l-4 bg-red-50 dark:bg-red-900/20 border-red-400';
    }

    resultIcon.textContent = icon;
    resultStatus.textContent = status;
    resultStatus.className = statusClass;
    resultText.textContent = text;

    // Untuk kondisi kuning dan merah, tampilkan link WA
    if (hppVal > 35) {
      resultAction.innerHTML =
        action +
        ` <a href="https://wa.me/628213141688?text=Halo%20Guslan,%20HPP%20saya%20${hppVal}%25%20dari%20omzet%20${Math.round(omzetVal).toLocaleString('id-ID')},%20saya%20butuh%20bantuan" target="_blank" rel="noopener noreferrer" class="block mt-2 text-primary font-semibold hover:underline">Diskusi dengan Guslan sekarang →</a>`;
    } else {
      resultAction.innerHTML =
        action +
        ` <a href="https://wa.me/628213141688?text=Halo%20Guslan,%20HPP%20saya%20${hppVal}%25%20dan%20saya%20ingin%20optimalkan%20lebih%20lanjut" target="_blank" rel="noopener noreferrer" class="block mt-2 text-primary font-semibold hover:underline">Konsultasi lebih lanjut →</a>`;
    }

    resultDiv.classList.remove('hidden');
  });
</script>

</Layout>