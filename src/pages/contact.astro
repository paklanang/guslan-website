---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Kontak — Guslan Putra | Konsultan Keuangan F&B Bali',
  description:
    'Hubungi Guslan Putra via WhatsApp, email, atau jadwalkan konsultasi gratis 45 menit. Melayani bisnis F&B di Bali dan seluruh Indonesia secara remote.',
};
---

<Layout metadata={metadata}>

  <!-- ═══ HERO ═══ -->
  <HeroText
    tagline="Kontak"
    title="Mari Bicara"
    subtitle="Konsultasi pertama gratis — tidak ada komitmen, tidak ada tekanan. Ceritakan kondisi bisnis Anda, saya bantu petakan masalah dan solusinya."
  />

  <!-- ═══ 3 CARA MENGHUBUNGI ═══ -->
  <Features2
    title="Pilih Cara yang Paling Nyaman"
    subtitle="Semua jalur aktif — saya jawab sendiri, biasanya dalam hitungan jam di hari kerja."
    columns={3}
    items={[
      {
        title: 'WhatsApp',
        description:
          'Cara tercepat. Langsung chat, tanya singkat, atau jadwalkan video call. Aktif Senin–Sabtu, 09.00–18.00 WITA.',
        icon: 'tabler:brand-whatsapp',
        callToAction: {
          text: 'Chat Sekarang →',
          href: 'https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20ingin%20konsultasi%20gratis',
          target: '_blank',
        },
      },
      {
        title: 'Email',
        description:
          'Untuk pertanyaan detail, kirim dokumen, atau diskusi yang butuh penjelasan panjang. Dibalas dalam 1×24 jam.',
        icon: 'tabler:mail',
        callToAction: {
          text: 'Kirim Email →',
          href: 'mailto:halo@guslan.com',
        },
      },
      {
        title: 'Free Health Check',
        description:
          'Video call 45 menit — review kondisi keuangan bisnis, identifikasi 3 masalah terbesar, rekomendasi prioritas perbaikan.',
        icon: 'tabler:stethoscope',
        callToAction: {
          text: 'Jadwalkan Sekarang →',
          href: 'https://wa.me/628213141688?text=Halo%20Guslan,%20saya%20ingin%20jadwalkan%20Free%20Financial%20Health%20Check%2045%20menit',
          target: '_blank',
        },
      },
    ]}
  />

  <!-- ═══ FORM + INFO KONTAK ═══ -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Form — 3/5 -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Kirim Pesan</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">
            Isi form di bawah — saya akan balas via WhatsApp atau email dalam 1×24 jam.
          </p>

          <form
            id="contactForm"
            class="space-y-5"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="nama" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                  Nama <span class="text-red-400">*</span>
                </label>
                <input
                  type="text"
                  id="nama"
                  name="nama"
                  required
                  placeholder="Nama Anda"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm"
                />
              </div>
              <div>
                <label for="bisnis" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                  Nama Bisnis
                </label>
                <input
                  type="text"
                  id="bisnis"
                  name="bisnis"
                  placeholder="Nama cafe / restoran Anda"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                  Email <span class="text-red-400">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="email@bisnis.com"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm"
                />
              </div>
              <div>
                <label for="wa" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                  Nomor WhatsApp
                </label>
                <input
                  type="tel"
                  id="wa"
                  name="wa"
                  placeholder="08xxxxxxxxxx"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm"
                />
              </div>
            </div>

            <div>
              <label for="topik" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                Topik yang Ingin Didiskusikan
              </label>
              <select
                id="topik"
                name="topik"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm"
              >
                <option value="">— Pilih topik —</option>
                <option value="bookkeeping">Sistem Pembukuan & Akuntansi</option>
                <option value="cogs">Analisis HPP & Menu Profitability</option>
                <option value="cashflow">Cash Flow & Perencanaan Keuangan</option>
                <option value="pajak">Pajak Restoran (PB1, PPh, PPN)</option>
                <option value="setup">Setup Sistem dari Awal</option>
                <option value="lainnya">Lainnya</option>
              </select>
            </div>

            <div>
              <label for="pesan" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">
                Ceritakan Situasi Bisnis Anda <span class="text-red-400">*</span>
              </label>
              <textarea
                id="pesan"
                name="pesan"
                required
                rows={4}
                placeholder="Contoh: Saya punya cafe di Canggu, omzet sekitar 80 juta/bulan, tapi tidak pernah tahu uangnya ke mana. Pembukuan masih manual di Excel..."
                class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition text-sm resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              id="submitBtn"
              class="w-full bg-primary hover:bg-teal-700 text-white font-bold py-3.5 rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98] text-sm"
            >
              Kirim Pesan via WhatsApp
            </button>

            <p class="text-xs text-slate-400 text-center">
              Form ini akan membuka WhatsApp dengan pesan yang sudah diisi otomatis.
            </p>
          </form>
        </div>

        <!-- Info Kontak — 2/5 -->
        <div class="lg:col-span-2 space-y-6">
          <div>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-5">Informasi Kontak</h3>
            <div class="space-y-4">
              {[
                {
                  icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
                  label: 'WhatsApp',
                  value: '+62 821 3141 688',
                  href: 'https://wa.me/628213141688',
                },
                {
                  icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
                  label: 'Email',
                  value: 'halo@guslan.com',
                  href: 'mailto:halo@guslan.com',
                },
                {
                  icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
                  label: 'Lokasi',
                  value: 'Kuta, Badung, Bali — Remote Friendly',
                  href: null,
                },
              ].map(({ icon, label, value, href }) => (
                <div class="flex items-start gap-3">
                  <div class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0" set:html={icon} />
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-0.5">{label}</p>
                    {href ? (
                      <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer" class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-primary transition-colors">
                        {value}
                      </a>
                    ) : (
                      <p class="text-sm font-medium text-slate-700 dark:text-slate-300">{value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Jam Operasional -->
          <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 border border-slate-100 dark:border-slate-700">
            <h4 class="font-bold text-slate-900 dark:text-white mb-4 text-sm uppercase tracking-widest">Jam Respons</h4>
            <div class="space-y-2.5">
              {[
                { hari: 'Senin – Jumat', jam: '09.00 – 18.00 WITA' },
                { hari: 'Sabtu', jam: '09.00 – 14.00 WITA' },
                { hari: 'Minggu & Hari Libur', jam: 'Di luar jadwal' },
              ].map(({ hari, jam }) => (
                <div class="flex justify-between items-center text-sm">
                  <span class="text-slate-500 dark:text-slate-400">{hari}</span>
                  <span class="font-medium text-slate-700 dark:text-slate-300">{jam}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-slate-400 mt-4 leading-relaxed">
              WhatsApp di luar jam kerja tetap diterima — akan dibalas di hari kerja berikutnya.
            </p>
          </div>

          <!-- Social -->
          <div>
            <h4 class="font-bold text-slate-900 dark:text-white mb-3 text-sm uppercase tracking-widest">Ikuti Saya</h4>
            <div class="flex gap-3">
              <a
                href="https://instagram.com/guslan.id"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:text-primary hover:bg-primary/10 transition-colors border border-slate-200 dark:border-slate-700"
                aria-label="Instagram"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
              <a
                href="https://linkedin.com/in/guslanputra"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:text-primary hover:bg-primary/10 transition-colors border border-slate-200 dark:border-slate-700"
                aria-label="LinkedIn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script is:inline>
  document.getElementById('contactForm').addEventListener('submit', function (e) {
    e.preventDefault();

    const nama = document.getElementById('nama').value.trim();
    const bisnis = document.getElementById('bisnis').value.trim();
    const email = document.getElementById('email').value.trim();
    const wa = document.getElementById('wa').value.trim();
    const topik = document.getElementById('topik').value;
    const pesan = document.getElementById('pesan').value.trim();

    const topikLabel = {
      bookkeeping: 'Sistem Pembukuan & Akuntansi',
      cogs: 'Analisis HPP & Menu Profitability',
      cashflow: 'Cash Flow & Perencanaan Keuangan',
      pajak: 'Pajak Restoran',
      setup: 'Setup Sistem dari Awal',
      lainnya: 'Lainnya',
    };

   let msg = `Halo Guslan, saya ingin konsultasi.\n`;
msg += `━━━━━━━━━━━━━━━━\n`;
msg += `Nama    : ${nama}\n`;
if (bisnis) msg += `Bisnis  : ${bisnis}\n`;
msg += `Email   : ${email}\n`;
if (wa) msg += `WA      : ${wa}\n`;
if (topik) msg += `Topik   : ${topikLabel[topik] || topik}\n`;
msg += `━━━━━━━━━━━━━━━━\n`;
msg += `${pesan}`;

    const url = `https://wa.me/628213141688?text=${encodeURIComponent(msg)}`;
    window.open(url, '_blank');
  });
</script>