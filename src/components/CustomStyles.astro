---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 116 217);
    --aw-color-secondary: rgb(255 133 27);
    --aw-color-accent: rgb(255 133 27);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: rgb(0 116 217 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 116 217);
    --aw-color-secondary: rgb(255 160 27);
    --aw-color-accent: rgb(255 160 27);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
/* Tombol WhatsApp Hijau */
header a[href*="wa.me"] {
  background-color: #25D366 !important;
  border-color: #25D366 !important;
  color: #ffffff !important;
}

header a[href*="wa.me"]:hover {
  background-color: #128C7E !important;
  border-color: #128C7E !important;
  color: #ffffff !important;
}  
</style>